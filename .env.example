# PostHog product analytics (optional).
# Copy this file to .env.local and fill in your own project's values.
# .env.local is gitignored and must NOT be committed.
#
# The project API key (phc_...) is safe to expose in the browser — it only
# grants event ingestion. Never put a Personal API key (phx_...) here.
#
# NEXT_PUBLIC_* vars are inlined at BUILD time, so they must be present in the
# environment when `opennextjs-cloudflare build` runs (deploy step), not just
# as a Cloudflare Worker runtime variable.

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
